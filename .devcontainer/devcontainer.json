{
  "name": "Livv Bites",
  "image": "mcr.microsoft.com/devcontainers/universal:2-linux",
  "forwardPorts": [8000],
  "portsAttributes": {
    "8000": { "label": "Livv Bites — site", "onAutoForward": "openPreview" }
  },
  "postAttachCommand": "python3 -m http.server 8000 --directory site",
  "customizations": {
    "vscode": {
      "extensions": ["ms-python.python", "ritwickdey.LiveServer"]
    }
  }
}
