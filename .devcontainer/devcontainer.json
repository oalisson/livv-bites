{
  "name": "Livv Bites",
  "image": "mcr.microsoft.com/devcontainers/universal:2-linux",
  "forwardPorts": [5500, 8000],
  "portsAttributes": {
    "5500": { "label": "Live Server", "onAutoForward": "openPreview" },
    "8000": { "label": "Livv Bites — http", "onAutoForward": "silent" }
  },
  "postAttachCommand": "python3 -m http.server 8000",
  "customizations": {
    "vscode": {
      "extensions": ["ms-python.python", "ritwickdey.LiveServer"],
      "settings": {
        "liveServer.settings.root": "/",
        "liveServer.settings.port": 5500,
        "liveServer.settings.NoBrowser": true,
        "liveServer.settings.host": "0.0.0.0"
      }
    }
  }
}
